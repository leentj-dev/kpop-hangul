default_platform(:ios)

APP_ID = "dev.leentj.kpopHangul"
TEAM_ID = "2U6RJTHK3V"

platform :ios do
  before_all do
    app_store_connect_api_key(
      key_id: "DPCWVWG2NC",
      issuer_id: "940731f5-e618-431d-921d-cc336fd1682a",
      key_filepath: "fastlane/AuthKey_DPCWVWG2NC.p8"
    )
  end

  # Run AFTER the bundle id + App Store Connect app exist (created via Apple ID
  # in the web UI). Everything here works with the API key alone.
  desc "Build a signed IPA and upload to TestFlight"
  lane :beta do
    sh("cd .. && flutter build ios --release --no-codesign --config-only")

    profile = get_provisioning_profile(app_identifier: APP_ID, readonly: false)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: TEAM_ID,
      bundle_identifier: APP_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::SIGH_NAME]
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: { APP_ID => lane_context[SharedValues::SIGH_NAME] }
      }
    )

    upload_to_testflight(skip_waiting_for_build_processing: true)
  end
end
